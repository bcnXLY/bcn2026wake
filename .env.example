# ---- Frontend (Vite, exposed to browser — public values only) ----
VITE_API_BASE_URL=https://xxxxxx.execute-api.eu-west-3.amazonaws.com/prod
VITE_GOOGLE_DRIVE_API_KEY=your_restricted_browser_key
VITE_GOOGLE_DRIVE_FOLDER_ID=your_public_folder_id
VITE_ONESIGNAL_APP_ID=your_onesignal_app_id
VITE_ENABLE_TEST_LOGIN_BUTTON=true

# ---- Backend / broadcast script only (NEVER commit real values; use GitHub Secrets) ----
AWS_REGION=eu-west-3
ONESIGNAL_APP_ID=your_onesignal_app_id
ONESIGNAL_REST_API_KEY=your_onesignal_rest_api_key
