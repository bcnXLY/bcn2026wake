# ---- Frontend (Vite, exposed to browser — public values only) ----
VITE_AWS_REGION=us-east-1
VITE_COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
VITE_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_API_BASE_URL=https://xxxxxx.execute-api.us-east-1.amazonaws.com/prod
VITE_GOOGLE_DRIVE_API_KEY=your_restricted_browser_key
VITE_GOOGLE_DRIVE_FOLDER_ID=your_public_folder_id
VITE_ONESIGNAL_APP_ID=your_onesignal_app_id
VITE_ENABLE_TEST_LOGIN_BUTTON=true

# ---- Backend / seed script only (NEVER commit real values; use GitHub Secrets) ----
AWS_REGION=us-east-1
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
